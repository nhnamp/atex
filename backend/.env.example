PORT=5000
# PostgreSQL (Supabase). DATABASE_URL: connection cho app; DIRECT_URL: cho prisma migrate/db push.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: model fallback chain (priority order, comma-separated). When a model
# is rate-limited (429) or overloaded (503) it is skipped and the next one is used.
# Leave unset to use the default chain below.
# GEMINI_MODELS=gemini-3.5-flash,gemini-3-flash-preview,gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite
# Optional: how long (ms) to skip a model after it returns 429/503 (default 60000).
# GEMINI_MODEL_COOLDOWN_MS=60000
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
FRONTEND_URL=http://localhost:5173
EXAM_MOBILE_SCAN_MAX_FILES=20
EXAM_SUBMISSION_SCAN_MAX_FILES=20
EXAM_BULK_SCAN_MAX_FILES=100
EXAM_MISSING_PAGE_MAX_FILES=20
ADMIN_PASSWORD=admin_password
