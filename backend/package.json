{
  "name": "atex-backend",
  "version": "1.0.0",
  "description": "ATEX - Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:reset-admin": "ts-node prisma/reset-admin.ts",
    "prisma:studio": "prisma studio",
    "setup": "npm install && npx prisma generate && npx prisma migrate dev --name init && ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "docxtemplater": "^3.68.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.5",
    "xlsx": "^0.18.5",
    "ts-node": "^10.9.2",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"

  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.5",
    "glob": "^11.1.0",
    "ts-node-dev": "^2.0.0"
  }
}
